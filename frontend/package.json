{
  "name": "jboard-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "vue-tsc -b --noEmit",
    "tauri": "tauri",
    "tauri:dev": "cd ../desktop && tauri dev",
    "tauri:build": "cd ../desktop && tauri build",
    "tauri:icon": "tauri icon ../desktop/src-tauri/icons/app-icon.svg"
  },
  "dependencies": {
    "@fontsource-variable/bricolage-grotesque": "^5.2.10",
    "@fontsource-variable/hanken-grotesk": "^5.2.8",
    "vue": "^3.5.13",
    "vue-draggable-plus": "^0.6.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/sortablejs": "^1.15.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/test-utils": "^2.4.11",
    "jsdom": "^29.1.1",
    "typescript": "~5.6.3",
    "vite": "^6.0.5",
    "vitest": "^4.1.9",
    "vue-tsc": "^2.2.0"
  }
}
