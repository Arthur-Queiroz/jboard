# jboard — variáveis de ambiente (copiar pra .env e ajustar)

# === Banco ===
# Senha do Postgres dedicado. Em DEV o docker-compose.yml usa "jboard" fixo;
# em PRODUÇÃO (docker-compose.prod.yml) esta variável é OBRIGATÓRIA.
# Gerar com: openssl rand -hex 24
JBOARD_DB_PASSWORD=jboard

# === Evolution API ===
# Chave de API da Evolution API (header apikey). Tem que ser igual nos 2 serviços.
JBOARD_EVOLUTION_API_KEY=changeme

# Nome da instância WhatsApp dentro da Evolution API.
JBOARD_EVOLUTION_INSTANCE=jboard

# Número de telefone do destinatário padrão dos lembretes (com DDI+DDD, sem +).
# Ex: 5511999999999 (Brasil, São Paulo, número fictício).
JBOARD_WHATSAPP_RECIPIENT=

# === Auth da API REST do jboard ===
# Token Bearer que protege a API em deploy público. Vazio = auth desligada (dev).
# Em PRODUÇÃO é OBRIGATÓRIO (o compose.prod falha se vazio). É o Bearer do
# DESKTOP e a chave que assina o cookie de sessão da web. A web NÃO embute mais
# esse token no bundle (autentica por senha → cookie).
# Gerar com: openssl rand -hex 32
JBOARD_API_TOKEN=

# Senha do LOGIN da web (troca o token-no-bundle por sessão em cookie httpOnly).
# Em PRODUÇÃO é OBRIGATÓRIA (o compose.prod falha se vazia). É a senha que você
# digita pra entrar em jboard.devarthur.com.br.
JBOARD_AUTH_PASSWORD=

# === CORS ===
# Allowlist de origens cross-origin (separadas por vírgula). Web e desktop-em-dev
# falam com a API na mesma origem e não precisam disto; só o desktop Tauri
# empacotado, cujo webview tem origem própria. Default cobre Linux/macOS/Windows;
# normalmente não precisa mexer.
JBOARD_CORS_ORIGINS=tauri://localhost,http://tauri.localhost
